{
  "name": "smart-building-fire-twin",
  "version": "0.1.0",
  "private": true,
  "description": "火灾模拟与消防数字孪生可视化平台",
  "scripts": {
    "dev": "npm-run-all --parallel dev:web dev:server",
    "dev:web": "npm --workspace apps/web run dev",
    "dev:server": "npm --workspace apps/server run dev",
    "build": "npm-run-all build:server build:web",
    "build:web": "npm --workspace apps/web run build",
    "build:server": "npm --workspace apps/server run build",
    "start": "npm --workspace apps/server run start",
    "typecheck": "npm-run-all typecheck:server typecheck:web",
    "typecheck:web": "npm --workspace apps/web run typecheck",
    "typecheck:server": "npm --workspace apps/server run typecheck"
  },
  "workspaces": [
    "apps/web",
    "apps/server"
  ],
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "playwright": "^1.61.1",
    "typescript": "^5.8.3"
  }
}
